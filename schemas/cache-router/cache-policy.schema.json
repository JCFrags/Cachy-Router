{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/cache-router/cache-policy.schema.json",
  "title": "Cache Router Policy",
  "description": "Minimal privacy-first cache policy contract for offline replay fixtures and future router prototypes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_id",
    "policy_id_hash",
    "default_scope",
    "allowed_scopes",
    "allow_global_system_cache",
    "allow_cross_tenant_reuse",
    "require_tenant_hash",
    "require_conversation_hash_for_conversation_scope",
    "allow_private_disabled_persistence",
    "user_content_global_cache_allowed",
    "operator_global_allowlist_hashes",
    "fallback_on_policy_denial",
    "audit_required",
    "encryption_at_rest_required"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2026-06-30.1"
    },
    "policy_id": {
      "$ref": "#/$defs/id_string"
    },
    "policy_id_hash": {
      "$ref": "#/$defs/sha256_hex"
    },
    "default_scope": {
      "$ref": "#/$defs/scope"
    },
    "allowed_scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scope"
      },
      "uniqueItems": true
    },
    "allow_global_system_cache": {
      "type": "boolean"
    },
    "allow_cross_tenant_reuse": {
      "type": "boolean",
      "const": false
    },
    "require_tenant_hash": {
      "type": "boolean",
      "const": true
    },
    "require_conversation_hash_for_conversation_scope": {
      "type": "boolean"
    },
    "allow_private_disabled_persistence": {
      "type": "boolean",
      "const": false
    },
    "user_content_global_cache_allowed": {
      "type": "boolean",
      "const": false
    },
    "operator_global_allowlist_hashes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sha256_hex"
      },
      "uniqueItems": true
    },
    "fallback_on_policy_denial": {
      "type": "string",
      "enum": [
        "cold_prefill",
        "reject_policy"
      ]
    },
    "audit_required": {
      "type": "boolean",
      "const": true
    },
    "encryption_at_rest_required": {
      "type": "boolean",
      "const": true
    },
    "notes": {
      "type": "string",
      "maxLength": 300
    }
  },
  "$defs": {
    "id_string": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]{1,128}$"
    },
    "sha256_hex": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "scope": {
      "type": "string",
      "enum": [
        "global_system",
        "tenant",
        "conversation",
        "private_disabled"
      ]
    }
  }
}
